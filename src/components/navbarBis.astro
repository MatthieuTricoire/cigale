---
// Importation des icônes pour Astro (nécessite l'installation de 'lucide-astro')
import { Menu } from '@lucide/astro';
---

<nav class="fixed top-0 w-full z-50 bg-white/80 backdrop-blur-md border-b border-sage/10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      
      <div class="flex items-center space-x-2">
        <a href="/">
          <svg class="w-20 h-20 text-primary" viewBox="0 0 104 66" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M27.8848 57.622V39.4108L41.429 27.1348L55.2269 39.2586V57.4698H44.8278V47.02H38.1825V57.5713L27.8848 57.622Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
            <path d="M1 62.0896C4.35718 60.3994 7.72694 59.6751 11.247 59.2995C15.3553 58.8612 19.5177 59.5061 23.6245 59.959C27.8852 60.4289 32.034 61.7413 36.3063 62.0896C40.7894 62.455 45.3807 62.8765 49.7999 62.0388C55.557 60.9475 62.0088 59.1208 64.3587 53.06C65.5475 49.9938 64.9705 46.502 65.5761 43.2696C67.8488 31.1401 75.1308 20.9342 79.932 20.5437C81.7808 20.3933 84.0677 26.8774 71.7142 28.5079C70.041 28.7288 68.4103 27.4892 67.0979 26.4281C63.9404 23.8751 62.3108 15.6228 66.337 14.4564C68.3553 13.8717 69.0994 18.0096 69.124 20.1107C69.1696 24.0065 67.0782 28.0831 64.2034 30.7128C62.2682 32.483 59.3271 34.0805 56.8003 33.3778C55.2909 32.958 56.341 30.3964 55.4306 29.2688C54.0328 27.5376 49.7221 30.0123 48.8868 27.9499C48.0241 25.8198 50.6104 22.9887 52.7928 22.2684C55.5603 21.355 59.0214 23.0279 61.0614 25.1092C64.1569 28.2675 64.1658 33.4361 65.1196 37.7403" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/">
          <span class="font-serif text-2xl font-bold tracking-tight text-sage">Cédric Gal Patrimoine</span>
        </a>
      </div>
      
      <div class="hidden md:flex items-center space-x-8">
        <a href="/#services" class="nav-link text-sage hover:text-primary transition-colors font-medium" data-section="services">Services</a>
        <a href="/#methodology" class="nav-link text-sage hover:text-primary transition-colors font-medium" data-section="methodology">Méthodologie</a>
        <a href="/#prestations" class="nav-link text-sage hover:text-primary transition-colors font-medium" data-section="prestations">Stratégies</a>
        <a href="/#about" class="nav-link text-sage hover:text-primary transition-colors font-medium" data-section="about">À Propos</a>
        <a href="/contact" class="bg-primary hover:bg-primary/90 text-background-dark font-bold py-2.5 px-6 rounded-lg transition-all shadow-lg shadow-primary/20">
          Prendre rendez-vous
        </a>
      </div>
      <script>
        const navLinks = document.querySelectorAll('.nav-link');
        const sections = ['services', 'prestations', 'methodology', 'about'];
        
        function updateActiveNav() {
          const scrollPos = window.scrollY + 100;
          
          for (const sectionId of sections) {
            const section = document.getElementById(sectionId);
            if (section) {
              const top = section.offsetTop;
              const height = section.offsetHeight;
              const isActive = scrollPos >= top && scrollPos < top + height;
              
              navLinks.forEach(link => {
                if (link.dataset.section === sectionId) {
                  if (isActive) {
                    link.classList.add('text-primary');
                    link.classList.remove('text-sage');
                  } else {
                    link.classList.remove('text-primary');
                    link.classList.add('text-sage');
                  }
                }
              });
            }
          }
        }
        
        window.addEventListener('scroll', updateActiveNav);
        updateActiveNav();
      </script>
      
      <div class="md:hidden">
        <Menu class="text-sage w-6 h-6 cursor-pointer" />
      </div>
      
    </div>
  </div>
</nav>
