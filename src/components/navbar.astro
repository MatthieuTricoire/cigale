---
import { SITE_DATA } from '../constants.ts'

const currentPath = Astro.url.pathname
---

<nav class="fixed top-0 w-full z-20 bg-white border-b border-gray-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <a href="/" class="flex items-center gap-3">
        <img src={SITE_DATA.logo} alt="Logo" class="size-20" />
        <div class="leading-tight">
          <p class="text-5xl font-heading font-bold text-gray-900">{SITE_DATA.title}</p>
          <!-- <p class="text-xs text-gray-500">{SITE_DATA.subtitle}</p> -->
        </div>
      </a>

      <ul class="hidden md:flex items-center gap-6">
        {SITE_DATA.navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class={`text-sm font-medium transition-colors hover:text-blue-600 ${
                currentPath === link.href
                  ? 'text-blue-600'
                  : 'text-gray-600'
              }`}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <button
        id="menu-toggle"
        type="button"
        class="md:hidden p-2 rounded-md text-gray-500 hover:text-gray-900 hover:bg-gray-100"
        aria-label="Ouvrir le menu"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-200 bg-white">
    <ul class="px-4 py-3 space-y-1">
      {SITE_DATA.navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class={`block py-2 text-sm font-medium rounded-md px-3 transition-colors hover:bg-gray-100 ${
              currentPath === link.href
                ? 'text-blue-600 bg-blue-50'
                : 'text-gray-700'
            }`}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  const toggle = document.getElementById('menu-toggle')
  const menu = document.getElementById('mobile-menu')
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden')
  })
</script>
