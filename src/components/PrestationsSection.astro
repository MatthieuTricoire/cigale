---
import { Home, TrendingUp, Wallet, Landmark, X, Heart, Receipt } from "@lucide/astro"

const categories = [
  {
    id: "placements",
    title: "Placements financiers",
    Icon: Wallet,
    items: [
      "Épargne financière",
      "Épargne immobilière",
      "Épargne retraite",
      "Épargne salariale",
      "Diversification",
      "Solutions fiscales"
    ],
    content: {
      subtitle: "Optimisez votre épargne avec des solutions adaptées à vos objectifs :",
      points: [
        "Épargne financière : Assurance-vie, Contrat de capitalisation, PEA assurance",
        "Épargne immobilière : SCPI de rendement, SCPI via SCI à l'IS, SCPI de capitalisation",
        "Épargne retraite : PERIN (Plan d'Épargne Retraite Individuel)",
        "Épargne salariale : PEE, PERECO",
        "Diversification : Fonds usufruit, FCPR et FPCI",
        "Solutions fiscales : SCPI fiscales, Capital investissement (FIP et FCPI)"
      ],
      cta: "Optimiser mon épargne"
    }
  },
  {
    id: "immobilier",
    title: "Investissements immobiliers",
    Icon: Home,
    items: [
      "LMNP",
      "LLI",
      "Colocation",
      "Jeanbrun",
      "Denormandie",
      "Malraux"
    ],
    content: {
      subtitle: "Investissez dans la pierre pour créer des revenus complémentaires durables :",
      points: [
        "LMNP (Location Meublée Non Professionnelle) : Avec ou sans exploitant",
        "LLI (Logement Locatif Intermédiaire) : Pour un investissement locatif intermédiaire",
        "Colocation : Optimisez la rentabilité de vos biens",
        "Nue-propriété : Profitez de la décote et constituez votre patrimoine",
        "Denormandie : Défiscalisation dans l'ancien à rénover",
        "Malraux / Monuments Historiques : Défiscalisation sur la restauration de bâtiments anciens"
      ],
      cta: "Démarrer un projet immobilier"
    }
  },
  {
    id: "financement",
    title: "Financement bancaire",
    Icon: Landmark,
    items: [
      "Financement immobilier",
      "Restructuration de crédit",
      "Prêt viager hypothécaire"
    ],
    content: {
      subtitle: "Structurez votre financement dans les meilleures conditions :",
      points: [
        "Financement immobilier : Différé partiel ou total, jusqu'à 25 ans",
        "Restructuration de crédit : Rachat de crédit, ajout de trésorerie, assurance emprunteur",
        "Prêt viager hypothécaire : Profitez de la valeur de votre bien sans vendre"
      ],
      cta: "Simuler mon financement"
    }
  },
  {
    id: "prevoyance",
    title: "Prévoyance",
    Icon: Heart,
    items: [
      "Prévoyance individuelle",
      "Prévoyance professionnelle"
    ],
    content: {
      subtitle: "Protégez vous et vos proches avec des solutions de prévoyance adaptées :",
      points: [
        "Prévoyance individuelle : Garantie décès, invalidité, arrêt de travail",
        "Prévoyance professionnelle : Protection de votre activité et de vos revenus"
      ],
      cta: "Configurer ma prévoyance"
    }
  },
  {
    id: "solutions-fiscales",
    title: "Solutions fiscales",
    Icon: Receipt,
    items: [
      "SCPI fiscales",
      "Capital investissement",
      "FIP et FCPI",
      "Déficit foncier"
    ],
    content: {
      subtitle: "Optimisez votre fiscalité avec des solutions légales :",
      points: [
        "SCPI fiscales : Investissement avec réduction d'impôt",
        "Capital investissement : FIP et FCPI pour investir dans les PME",
        "Déficit foncier : Déduction des travaux de rénovation de vos revenus"
      ],
      cta: "Optimiser ma fiscalité"
    }
  }
];
---

<section id="prestations" class="py-24 scroll-mt-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
<h2 class="font-serif text-4xl text-sage mb-4 text-balance">Un panel de <span class="text-gold italic">solutions</span> pour mettre en place la <span class="text-gold italic">stratégie</span> qui vous correspond</h2>
      <p class="text-sage/60 max-w-2xl mx-auto">Une approche globale et objective, sans exclusivité. Ensemble, nous choisissons les meilleures solutions du marché qui correspondent à vos objectifs et votre profil de risque.</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {categories.map((category) => {
        const Icon = category.Icon;
        return (
          <button type="button" onclick={`document.getElementById('modal-${category.id}').showModal()`} class="bg-white p-8 rounded-xl shadow-sm border border-sage/5 hover:cursor-pointer hover:border-primary/30 transition-all hover:-translate-y-2 group text-left w-full flex flex-col h-full">
            <div class="flex items-center gap-4 mb-4">
              <div class="w-14 h-14 bg-beige rounded-lg flex items-center justify-center group-hover:bg-primary transition-colors flex-shrink-0">
                <Icon class="w-7 h-7 text-gold group-hover:text-white" />
              </div>
              <h3 class="font-serif text-xl text-sage">{category.title}</h3>
            </div>
            
            <div class="flex flex-wrap gap-2 mb-6">
              {category.items.map((item) => (
                <span class="px-3 py-1.5 bg-beige text-sage/80 text-xs font-medium rounded-lg">
                  {item}
                </span>
              ))}
            </div>
            
            <span class="text-primary font-bold text-sm flex items-center mt-auto justify-end">
              En savoir plus
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="m9 18 6-6-6-6" />
              </svg>
            </span>
          </button>
        );
      })}
    </div>
  </div>
</section>

{categories.map((category) => (
  <dialog id={`modal-${category.id}`} class="modal-dialog" onclick="if (event.target === this) this.close()">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-2xl max-h-[90vh] overflow-hidden">
      <div class="bg-sage p-6 flex justify-between items-center">
        <h3 class="font-serif text-2xl text-white">{category.title}</h3>
        <button type="button" onclick={`document.getElementById('modal-${category.id}').close()`} class="text-white/70 hover:text-white transition-colors p-2">
          <X class="w-6 h-6" />
        </button>
      </div>
      <div class="p-8 overflow-y-auto max-h-[calc(90vh-100px)]">
        <p class="text-sage/80 text-lg mb-6">{category.content.subtitle}</p>
        <ul class="space-y-4">
          {category.content.points.map((point) => (
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 bg-gold rounded-full mt-2 flex-shrink-0"></span>
              <span class="text-sage/70">{point}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </dialog>
))}

<style>
  dialog {
    padding: 1rem;
    border: none;
    background: transparent;
    width: 100%;
    max-width: 42rem;
    margin: auto;
  }
  
  dialog::backdrop {
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    animation: fadeIn 0.2s ease;
  }
  
  dialog[open] {
    animation: slideIn 0.2s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes slideIn {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
  }
</style>
