---
import { Home, TrendingUp, Wallet, Landmark, X } from "@lucide/astro"

const categories = [
  {
    id: "immobilier",
    title: "Investissements immobiliers",
    Icon: Home,
    items: ["LMNP / LMP","Nu propriété", "LLI", "Colocation", "Malraux / Monument Historique"],
    content: {
      subtitle: "Investissez dans la pierre pour créer des revenus complémentaires durables :",
      points: [
        "LMNP / LMP : Loueur meublé non professionnel ou professionnel pour bénéficier de revenus locatifs fiscalisés",
        "Pinel / Denormandie : Défiscalisationrté dans le neuf avec réduction d'impôt avantageuse",
        "SCPI / OPCI : Investissement clé en main sans gestion locative, avec revenus réguliers",
        "Malraux / Monument Historique : Défiscalisation sur la restauration de bâtiments anciens",
      ],
      cta: "Démarrer un projet immobilier"
    }
  },
  {
    id: "instruments",
    title: "Instruments financiers",
    Icon: TrendingUp,
    items: ["Private Equity", "Produits Structurés", "Girardin Industriel", "FIP / FCPI"],
    content: {
      subtitle: "Accédez à des solutions de diversification pour optimiser votre patrimoine",
      points: [
        "Private Equity : Investissement dans des entreprises non cotées à fort potentiel de croissance",
        "Produits Structurés : Solutions personnalisées combinant rendements et protection du capital",
        "Girardin Industriel : Investissement dans les DOM-TOM avec avantage fiscal significatif",
        "FIP / FCPI : Fonds dédiés aux PME innovantes avec réduction d'impôt sur le revenu",
      ],
      cta: "Explorer les opportunités financières"
    }
  },
  {
    id: "placements",
    title: "Placements financiers",
    Icon: Wallet,
    items: ["Assurance-vie", "PER (Plan Épargne Retraite)", "Contrat de Capitalisation" ],
    content: {
      subtitle: "Optimisez vos placements avec une stratégie adaptée à vos objectifs",
      points: [
        "Assurance-vie : Supports variés, transmission du capital, flexibilité des rachats",
        "PER : Constitution d'un complément retraite avec avantages fiscaux",
        "Contrat de Capitalisation : Transmission optimisée hors succession",
        "PEA / Compte Titres : Gestion directive ou conseillée sur les marchés actions et obligations",
      ],
      cta: "Optimiser mes placements"
    }
  },
  {
    id: "financement",
    title: "Financement bancaire",
    Icon: Landmark,
    items: ["Prêt Immobilier", "Crédit Lombard", "Rachat de Crédits", "Financement Professionnel"],
    content: {
      subtitle: "Structurez votre financement dans les meilleures conditions du marché",
      points: [
        "Prêt Immobilier : Négociation de taux et montage optimal pour votre acquisition",
        "Crédit Lombard : Financement sécurisé par votre portefeuille d'actifs",
        "Rachat de Crédits : Regroupement de vos crédits pour améliorer votre trésorerie",
        "Financement Professionnel : Solutions adaptées aux besoins de votre activité",
      ],
      cta: "Simuler mon financement"
    }
  },
];
---

<section id="prestations" class="py-24 scroll-mt-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
<h2 class="font-serif text-4xl text-sage mb-4 text-balance">Un panel de <span class="text-gold italic">solutions</span> pour mettre en place la <span class="text-gold italic">stratégie</span> qui vous correspond</h2>
      <p class="text-sage/60 max-w-2xl mx-auto">Une approche globale et objective, sans exclusivité. Ensemble, nous choisissons les meilleures solutions du marché qui correspondent à vos objectifs et votre profil de risque.</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {categories.map((category) => {
        const Icon = category.Icon;
        return (
          <button type="button" onclick={`document.getElementById('modal-${category.id}').showModal()`} class="bg-white p-8 rounded-xl shadow-sm border border-sage/5 hover:cursor-pointer hover:border-primary/30 transition-all hover:-translate-y-2 group text-left w-full">
            <div class="w-14 h-14 bg-beige rounded-lg flex items-center justify-center mb-6 group-hover:bg-primary transition-colors">
              <Icon class="w-7 h-7 text-gold group-hover:text-white" />
            </div>
            
            <h3 class="font-serif text-xl text-sage mb-4">{category.title}</h3>
            
            <div class="flex flex-wrap gap-2 mb-6">
              {category.items.map((item) => (
                <span class="px-3 py-1.5 bg-beige text-sage/80 text-xs font-medium rounded-lg">
                  {item}
                </span>
              ))}
            </div>
            
            <span class="text-primary font-bold text-sm flex items-center">
              En savoir plus
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="m9 18 6-6-6-6" />
              </svg>
            </span>
          </button>
        );
      })}
    </div>
  </div>
</section>

{categories.map((category) => (
  <dialog id={`modal-${category.id}`} class="modal-dialog" onclick="if (event.target === this) this.close()">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-2xl max-h-[90vh] overflow-hidden">
      <div class="bg-sage p-6 flex justify-between items-center">
        <h3 class="font-serif text-2xl text-white">{category.title}</h3>
        <button type="button" onclick={`document.getElementById('modal-${category.id}').close()`} class="text-white/70 hover:text-white transition-colors p-2">
          <X class="w-6 h-6" />
        </button>
      </div>
      <div class="p-8 overflow-y-auto max-h-[calc(90vh-100px)]">
        <p class="text-sage/80 text-lg mb-6">{category.content.subtitle}</p>
        <ul class="space-y-4">
          {category.content.points.map((point) => (
            <li class="flex items-start gap-3">
              <span class="w-2 h-2 bg-gold rounded-full mt-2 flex-shrink-0"></span>
              <span class="text-sage/70">{point}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </dialog>
))}

<style>
  dialog {
    padding: 1rem;
    border: none;
    background: transparent;
    width: 100%;
    max-width: 42rem;
    margin: auto;
  }
  
  dialog::backdrop {
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    animation: fadeIn 0.2s ease;
  }
  
  dialog[open] {
    animation: slideIn 0.2s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes slideIn {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
  }
</style>
