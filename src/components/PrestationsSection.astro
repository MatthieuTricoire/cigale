---
import { Home, TrendingUp, Wallet, Landmark } from "@lucide/astro"

const categories = [
  {
    title: "Investissements immobiliers",
    Icon: Home,
    items: ["LMNP / LMP", "Pinel / Denormandie", "SCPI / OPCI", "Malraux / Monument Historique"],
  },
  {
    title: "Instruments financiers",
    Icon: TrendingUp,
    items: ["Private Equity", "Produits Structurés", "Girardin Industriel", "FIP / FCPI"],
  },
  {
    title: "Placements financiers",
    Icon: Wallet,
    items: ["Assurance-vie", "PER (Plan Épargne Retraite)", "Contrat de Capitalisation", "PEA / Compte Titres"],
  },
  {
    title: "Financement bancaire",
    Icon: Landmark,
    items: ["Prêt Immobilier", "Crédit Lombard", "Rachat de Crédits", "Financement Professionnel"],
  },
];
---

<section class="py-24 scroll-mt-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="font-serif text-4xl text-sage mb-4">Une stratégie <span class="italic text-gold">360°</span></h2>
      <p class="text-sage/60 max-w-2xl mx-auto">L'intégralité du marché, au service de votre patrimoine.
Finance, immobilier, transmission : bénéficiez d'une stratégie globale et d'une objectivité totale. Libre de toute exclusivité, je sélectionne avec vous l'élite des solutions d'investissement pour bâtir un portefeuille véritablement diversifié et sur-mesure.</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {categories.map((category, index) => {
        const Icon = category.Icon;
        return (
          <div class="bg-white p-8 rounded-xl shadow-sm border border-sage/5 hover:border-primary/30 transition-all hover:-translate-y-2 group">
            <div class="w-14 h-14 bg-beige rounded-lg flex items-center justify-center mb-6 group-hover:bg-primary transition-colors">
              <Icon class="w-7 h-7 text-gold group-hover:text-white" />
            </div>
            
            <h3 class="font-serif text-xl text-sage mb-4">{category.title}</h3>
            
            <div class="flex flex-wrap gap-2 mb-6">
              {category.items.map((item) => (
                <span class="px-3 py-1.5 bg-beige text-sage/80 text-xs font-medium rounded-lg">
                  {item}
                </span>
              ))}
            </div>
            
            <a href="#" class="text-primary font-bold text-sm flex items-center">
              En savoir plus
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="m9 18 6-6-6-6" />
              </svg>
            </a>
          </div>
        );
      })}
    </div>
  </div>
</section>
