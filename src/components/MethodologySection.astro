---
const steps = [
  {
    number: "01",
    title: "Écoute & Bilan",
    description: "Comprendre vos valeurs, vos craintes et vos aspirations est ma priorité. Ensemble, nous dressons un bilan patrimonial qui va bien au-delà des simples chiffres."
  },
  {
    number: "02",
    title: "Définition de la stratégie",
    description: "À partir de votre situation unique, je conçois un plan d'action précis pour aligner la gestion de votre capital sur chaque étape de votre vie."
  },
  {
    number: "03",
    title: "Mise en place de la stratégie",
    description: "Blabla à mettre pour le suivi de la stratégie"
  },
  {
    number: "04",
    title: "Suivi sur la durée",
    description: "Votre patrimoine est vivant. Je pilote et ajuste votre stratégie au gré de l'évolution de vos projets personnels, de la fiscalité et des marchés financiers."
  }
];
---

<section id="methodology" class="py-24 bg-sage text-white scroll-mt-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="font-serif text-4xl mb-4">La clarté et le sur-mesure au service de vos intérêts</h2>
      <p class="text-slate-300 text-lg max-w-2xl mx-auto">Face à la complexité des marchés financiers, de l'immobilier et de la fiscalité, mon objectif est simple : vous faire gagner en sérénité. Je vous propose un accompagnement 100 % sur mesure et pédagogique.</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {steps.map((step) => (
        <div class="bg-white/5 p-8 rounded-xl border border-white/10 backdrop-blur-sm text-center">
          <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-primary flex items-center justify-center font-bold text-background-dark text-2xl">
            {step.number}
          </div>
          <h4 class="font-bold text-xl mb-4">{step.title}</h4>
          <p class="text-slate-300 text-sm leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
