
---
import '../styles/global.css'
import NavbarBis from './navbarBis.astro'

interface Props {
  title?: string
  description?: string
}


---

<!DOCTYPE html>
<html lang="fr" style="scrollbar-gutter: stable; scroll-behavior: smooth;">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body id="top" class="bg-surface flex flex-col min-h-screen">
    <NavbarBis />
    <main class="pt-16 flex-1">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <slot />
      </div>
    </main>
    <footer class="bg-gray-900 text-white py-12">
      footer
    </footer>
    <a href="#top" id="scroll-top-btn" class="fixed bottom-6 right-6 bg-primary text-white p-3 rounded-full shadow-lg shadow-primary/30 hover:bg-primary/90 transition-all duration-300 z-50 opacity-0 pointer-events-none" aria-label="Retour en haut">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
      </svg>
    </a>
    <script>
      const btn = document.getElementById('scroll-top-btn');
      let isVisible = false;
      
      window.addEventListener('scroll', () => {
        const shouldShow = window.scrollY > 100;
        if (shouldShow !== isVisible) {
          isVisible = shouldShow;
          btn?.classList.toggle('opacity-0', !isVisible);
          btn?.classList.toggle('pointer-events-none', !isVisible);
        }
      });
    </script>
  </body>
</html>
